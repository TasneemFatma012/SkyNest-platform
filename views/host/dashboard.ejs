<%- layout("layouts/boilerplate") %>
<link rel="stylesheet" href="/CSS/hostDashboard.css">
<div class="host-dashboard">

    <!-- =========================
         DASHBOARD HEADER
    ========================== -->

    <div class="dashboard-header">

        <div>

            <span class="dashboard-badge">
                🏠 Host Panel
            </span>

            <h1>
                Welcome back,
                <%= currUser.username %> 👋
            </h1>

            <p>
                Manage your listings, bookings and revenue from one place.
            </p>

        </div>

        <div>

            <a href="/listings/new" class="dashboard-btn">

                + Add Listing

            </a>

        </div>

    </div>



    <!-- =========================
         KPI CARDS
    ========================== -->

    <div class="stats-grid">

        <div class="stat-card">

            <div class="stat-icon">
                💰
            </div>

            <div>

                <h2>
                    ₹<%= revenue.toLocaleString("en-IN") %>
                </h2>

                <p>Total Revenue</p>

            </div>

        </div>



        <div class="stat-card">

            <div class="stat-icon">
                📅
            </div>

            <div>

                <h2>
                    <%= totalBookings %>
                </h2>

                <p>Total Bookings</p>

            </div>

        </div>



        <div class="stat-card">

            <div class="stat-icon">
                🏡
            </div>

            <div>

                <h2>
                    <%= totalListings %>
                </h2>

                <p>Active Listings</p>

            </div>

        </div>



        <div class="stat-card">

            <div class="stat-icon">
                📈
            </div>

            <div>

                <h2>
                    <%= conversionRate %>%
                </h2>

                <p>Conversion Rate</p>

            </div>

        </div>



        <div class="stat-card">

            <div class="stat-icon">
                ❌
            </div>

            <div>

                <h2>
                    <%= cancelledBookings %>
                </h2>

                <p>Cancelled</p>

            </div>

        </div>



        <div class="stat-card">

            <div class="stat-icon">
                🔔
            </div>

            <div>

                <h2>
                    <%= notifications.length %>
                </h2>

                <p>Notifications</p>

            </div>

        </div>

    </div>



    <!-- =========================
         CHART SECTION
    ========================== -->

    <div class="charts-grid">

        <!-- Revenue -->

        <div class="chart-card">

            <div class="chart-header">

                <h3>
                    📈 Revenue Trend
                </h3>

                <span>
                    Last 6 Months
                </span>

            </div>

            <canvas id="revenueChart"></canvas>

        </div>



        <!-- Bookings -->

        <div class="chart-card">

            <div class="chart-header">

                <h3>
                    📊 Booking Status
                </h3>

                <span>
                    Overview
                </span>

            </div>

            <canvas id="bookingChart"></canvas>

        </div>

    </div>



    <!-- =========================
         QUICK ACTIONS
    ========================== -->

    <div class="quick-actions">

        <a href="/listings/new" class="action-card">

            <div class="action-icon">
                ➕
            </div>

            <h4>Add Listing</h4>

            <p>Create a new property</p>

        </a>



        <a href="/listings" class="action-card">

            <div class="action-icon">
                🏡
            </div>

            <h4>Manage Listings</h4>

            <p>Edit your properties</p>

        </a>



        <a href="/host/bookings" class="action-card">

            <div class="action-icon">
                📅
            </div>

            <h4>Bookings</h4>

            <p>View reservations</p>

        </a>



        <a href="/host/export/csv" class="action-card">

            <div class="action-icon">
                📥
            </div>

            <h4>Export Report</h4>

            <p>Download revenue report</p>

        </a>

    </div>
 
<!-- ===================================
        BOOKING CALENDAR
=================================== -->

<div class="dashboard-section mt-4">

    <div class="section-header">

        <h2>📅 Booking Calendar</h2>

        <button
            class="dashboard-btn"
            data-bs-toggle="modal"
            data-bs-target="#blockDateModal">

            🚫 Block Dates

        </button>

    </div>

    <div class="calendar-card">

        <div id="calendar"></div>

    </div>

</div>


<!-- ===================================
        BLOCK DATE MODAL
=================================== -->

<div
    class="modal fade"
    id="blockDateModal"
    tabindex="-1"
    aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">

                    🚫 Block Dates

                </h5>

                <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <div class="mb-3">

                    <label class="form-label">

                        Select Listing

                    </label>

                    <select
                        id="listingSelect"
                        class="form-select">

                        <% listings.forEach(listing=>{ %>

                        <option value="<%= listing._id %>">

                            <%= listing.title %>

                        </option>

                        <% }) %>

                    </select>

                </div>

                <div class="alert alert-info">

                    📅 Select dates directly on the calendar to block them.

                </div>

            </div>

            <div class="modal-footer">

                <button
                    class="btn btn-secondary"
                    data-bs-dismiss="modal">

                    Close

                </button>

            </div>

        </div>

    </div>

</div>


<!-- ✅ MOVE MODAL HERE (OUTSIDE ALL SECTIONS) -->

<div class="modal fade" id="blockDateModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Block Dates</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">
        <p>Select dates to block</p>
        <select id="listingSelect">
  <% listings.forEach(listing => { %>
    <option value="<%= listing._id %>">
      <%= listing.title %>
    </option>
  <% }) %>
</select>
       

    <button type="submit" class="btn btn-danger mt-2">
      Block Dates
    </button>



      </div>

    </div>
  </div>
</div>

<!-- ===================================
        REVENUE + BOOKINGS
=================================== -->

<div class="dashboard-row mt-4">

    <!-- Revenue Per Listing -->

    <div class="dashboard-card">

        <div class="card-header">

            <h3>
                💰 Revenue Per Listing
            </h3>

        </div>

        <table class="listing-table">

            <thead>

                <tr>

                    <th>Listing</th>

                    <th>Bookings</th>

                    <th>Revenue</th>

                </tr>

            </thead>

            <tbody>

                <% listings.forEach(listing=>{ %>

                    <tr>

                        <td>

                            <strong>

                                <%= listing.title %>

                            </strong>

                        </td>

                        <td>

                            <%= listingRevenue[listing._id]?.bookings || 0 %>

                        </td>

                        <td>

                            ₹<%= listingRevenue[listing._id]?.revenue || 0 %>

                        </td>

                    </tr>

                <% }) %>

            </tbody>

        </table>

    </div>



    <!-- Latest Bookings -->

    <div class="dashboard-card">

        <div class="card-header">

            <h3>

                🛏 Latest Bookings

            </h3>

        </div>

        <% if(totalBookings>0){ %>

        <table class="listing-table">

            <thead>

                <tr>

                    <th>Listing</th>

                    <th>Status</th>

                </tr>

            </thead>

            <tbody>

                <% listings.slice(0,5).forEach(listing=>{ %>

                    <tr>

                        <td>

                            <%= listing.title %>

                        </td>

                        <td>

                            <span class="badge bg-success">

                                Active

                            </span>

                        </td>

                    </tr>

                <% }) %>

            </tbody>

        </table>

        <% } else { %>

            <div class="empty-card">

                <i class="fa-solid fa-calendar-xmark"></i>

                <p>

                    No bookings yet.

                </p>

            </div>

        <% } %>

    </div>

</div>


<!-- ===================================
            HOST LISTINGS
=================================== -->

<div class="dashboard-section mt-4">

    <div class="card-header">

        <h2>

            🏡 Your Listings

        </h2>

    </div>

    <table class="listing-table">

        <thead>

            <tr>

                <th>Listing</th>

                <th>Price</th>

                <th>Status</th>

                <th>Views</th>

                <th>Action</th>

            </tr>

        </thead>

        <tbody>

            <% listings.forEach(listing=>{ %>

            <tr>

                <td>

                    <%= listing.title %>

                </td>

                <td>

                    ₹<%= listing.price %>

                </td>

                <td>

                    <span class="badge bg-success">

                        Active

                    </span>

                </td>

                <td>

                    <%= listing.views || 0 %>

                </td>

                <td>

                    <a

                        href="/listings/<%= listing._id %>/edit"

                        class="btn btn-sm btn-dark">

                        Edit

                    </a>

                </td>

            </tr>

            <% }) %>

        </tbody>

    </table>

</div>



<!-- ===================================
            NOTIFICATIONS
=================================== -->

<div class="dashboard-section mt-4">

    <div class="card-header">

        <h2>

            🔔 Recent Notifications

        </h2>

    </div>

    <% if(notifications.length){ %>

        <% notifications.forEach(notification=>{ %>

            <div class="notification-card">

                <div>

                    🔔

                </div>

                <div>

                    <%= notification.message %>

                </div>

            </div>

        <% }) %>

    <% } else { %>

        <div class="empty-card">

            <i class="fa-solid fa-bell-slash"></i>

            <p>

                No notifications available.

            </p>

        </div>

    <% } %>

</div>
<!-- ===================================
            SMART SUGGESTIONS + PRICING
=================================== -->

<div class="dashboard-row mt-4">

    <div class="dashboard-card">

        <div class="card-header">
            <h3>💡 Smart Suggestions</h3>
        </div>

        <div class="ai-item">
            <span>📈</span>
            <div>
                Weekend demand is increasing.
                <strong>Increase prices by 12%</strong>
            </div>
        </div>

        <div class="ai-item">
            <span>🔥</span>
            <div>
                <strong>
                    <%= listings[0]?.title || "Listing" %>
                </strong>
                is currently trending.
            </div>
        </div>

        <div class="ai-item">
            <span>⭐</span>
            <div>
                Guests prefer stays having
                <strong>4+ photos.</strong>
            </div>
        </div>

        <div class="ai-item">
            <span>💰</span>
            <div>
                Expected revenue increase:
                <strong>+18%</strong>
            </div>
        </div>

    </div>



    <!-- ============================
          PRICING SUGGESTION
    ============================= -->

    <div class="dashboard-card">

        <div class="card-header">
            <h3>💎 AI Pricing</h3>
        </div>

        <% if(listings.length){ %>

        <div class="pricing-box">

            <h2>
                ₹<%= listings[0].price %>
            </h2>

            <small>Current Price</small>

            <hr>

            <h2 style="color:green">
                ₹<%= Math.round(listings[0].price*1.12) %>
            </h2>

            <small>Suggested Price</small>

            <p class="mt-3">

                Estimated Revenue Boost

                <strong style="color:green">
                    +12%
                </strong>

            </p>

        </div>

        <% } %>

    </div>

</div>



<!-- ===================================
        TOP LISTINGS
=================================== -->

<div class="dashboard-section mt-4">

    <div class="card-header">

        <h2>
            🏆 Top Performing Listings
        </h2>

    </div>

    <table class="listing-table">

        <thead>

            <tr>

                <th>#</th>

                <th>Listing</th>

                <th>Revenue</th>

                <th>Bookings</th>

            </tr>

        </thead>

        <tbody>

        <% listings.forEach((listing,index)=>{ %>

            <tr>

                <td>

                    <% if(index==0){ %>🥇<% } %>
                    <% if(index==1){ %>🥈<% } %>
                    <% if(index==2){ %>🥉<% } %>

                    <% if(index>2){ %>

                    <%= index+1 %>

                    <% } %>

                </td>

                <td>

                    <%= listing.title %>

                </td>

                <td>

                    ₹<%= listingRevenue[listing._id]?.revenue || 0 %>

                </td>

                <td>

                    <%= listingRevenue[listing._id]?.bookings || 0 %>

                </td>

            </tr>

        <% }) %>

        </tbody>

    </table>

</div>



<!-- ===================================
        GUEST REVIEWS
=================================== -->

<div class="dashboard-section mt-4">

    <div class="card-header">

        <h2>
            ⭐ Recent Reviews
        </h2>

    </div>

    <div class="review-grid">

        <div class="review-card">

            <h4>★★★★★</h4>

            <p>

                Amazing stay.

                Everything was clean.

            </p>

            <small>

                — John

            </small>

        </div>



        <div class="review-card">

            <h4>★★★★★</h4>

            <p>

                Beautiful location.

                Highly recommended.

            </p>

            <small>

                — Sarah

            </small>

        </div>



        <div class="review-card">

            <h4>★★★★☆</h4>

            <p>

                Nice experience.

                Will visit again.

            </p>

            <small>

                — Alex

            </small>

        </div>

    </div>

</div>



<!-- ===================================
        EXPORT REPORT
=================================== -->

<div class="dashboard-section mt-4">

    <div class="card-header">

        <h2>

            📥 Export Reports

        </h2>

    </div>

    <div class="export-buttons">

        <a href="/host/export/csv"
           class="dashboard-btn">

            CSV

        </a>

        <a href="/host/export/pdf"
           class="dashboard-btn">

            PDF

        </a>

        <a href="/host/export/excel"
           class="dashboard-btn">

            Excel

        </a>

    </div>

</div>
<!-- Recent Bookings -->

<div class="dashboard-section mt-4">

    <div class="section-header">
        <h3>🛎 Recent Bookings</h3>
    </div>

    <% if(recentBookings.length){ %>

    <table class="listing-table">

        <thead>

            <tr>
                <th>Guest</th>
                <th>Listing</th>
                <th>Check In</th>
                <th>Check Out</th>
                <th>Amount</th>
                <th>Status</th>
            </tr>

        </thead>

        <tbody>

        <% recentBookings.forEach(b=>{ %>

            <tr>

                <td>
                    <%= b.user?.username || "Guest" %>
                </td>

                <td>
                    <%= b.listing?.title %>
                </td>

                <td>
                    <%= new Date(b.checkIn).toLocaleDateString("en-IN") %>
                </td>

                <td>
                    <%= new Date(b.checkOut).toLocaleDateString("en-IN") %>
                </td>

                <td>
                    ₹<%= b.amount %>
                </td>

                <td>

                    <% if(b.status==="confirmed"){ %>

                        <span class="badge bg-success">
                            Confirmed
                        </span>

                    <% } else { %>

                        <span class="badge bg-danger">
                            Cancelled
                        </span>

                    <% } %>

                </td>

            </tr>

        <% }) %>

        </tbody>

    </table>

    <% } else { %>

        <div class="empty-card">
            No bookings yet.
        </div>

    <% } %>

</div>
<!-- =========================
AI Insights
========================== -->

<div class="dashboard-section mt-4">

    <div class="card-header">
        <h3>
            🤖 AI Insights
        </h3>
    </div>

    <div class="ai-grid">

        <!-- Best Listing -->

        <div class="ai-card success">

            <h4>
                🔥 Top Performing Listing
            </h4>

            <% 
            let best = null;

            listings.forEach(l=>{

                if(
                    !best ||
                    (listingRevenue[l._id]?.revenue || 0)
                    >
                    (listingRevenue[best._id]?.revenue || 0)
                ){
                    best=l;
                }

            });
            %>

            <% if(best){ %>

                <strong>
                    <%= best.title %>
                </strong>

                <p>

                    Revenue :
                    ₹<%= listingRevenue[best._id]?.revenue || 0 %>

                </p>

            <% } %>

        </div>

        <!-- Lowest -->

        <div class="ai-card warning">

            <h4>
                ⚠ Needs Improvement
            </h4>

            <%

            let lowest=null;

            listings.forEach(l=>{

                if(
                    !lowest ||
                    (listingRevenue[l._id]?.revenue || 0)
                    <
                    (listingRevenue[lowest._id]?.revenue || 0)
                ){
                    lowest=l;
                }

            });

            %>

            <% if(lowest){ %>

            <strong>

                <%= lowest.title %>

            </strong>

            <p>

                Revenue :
                ₹<%= listingRevenue[lowest._id]?.revenue || 0 %>

            </p>

            <% } %>

        </div>

        <!-- AI Recommendation -->

        <div class="ai-card">

            <h4>
                🤖 Recommendation
            </h4>

            <ul>

                <li>
                    Increase weekend price by 10%
                </li>

                <li>
                    Add more photos
                </li>

                <li>
                    Reply reviews quickly
                </li>

                <li>
                    Enable Instant Booking
                </li>

            </ul>

        </div>

        <!-- Occupancy -->

        <div class="ai-card info">

            <h4>

                📈 Occupancy

            </h4>

            <h2>

                92%

            </h2>

            <small>

                Better than last month

            </small>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
window.dashboardData = {
    chartLabels: <%- JSON.stringify(chartLabels) %>,
    revenueChart: <%- JSON.stringify(revenueChart) %>,
    bookingChart: <%- JSON.stringify(bookingChart) %>
};
</script>


<link rel="stylesheet"
href="https://unpkg.com/tippy.js@6/dist/tippy.css">

<script src="https://unpkg.com/@popperjs/core@2"></script>

<script src="https://unpkg.com/tippy.js@6"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>