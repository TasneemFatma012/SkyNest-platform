<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SkyNest</title>


  <!-- ① Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
 
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,600&family=Manrope:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />

 
  <!-- ③ Font Awesome -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    crossorigin="anonymous"
    referrerpolicy="no-referrer"
  />

  <!-- ④ Bootstrap 5 CSS -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
  />

  <!-- ⑤ Mapbox GL -->
  <link
    href="https://api.mapbox.com/mapbox-gl-js/v2.9.1/mapbox-gl.css"
    rel="stylesheet"
  />

  <link rel="stylesheet" href="/CSS/style.css" />
  
 

  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
</head>

<body>

<%- include("../includes/navbar") %>

  <!-- ── FLASH MESSAGES ── -->
  <div class="container-fluid px-0">
    <div style="padding: 0 28px; margin-top: 10px;">
      <%- include('../includes/flash') %>
    </div>
  </div>

  <!-- ── PAGE CONTENT ── -->
  <main>
    <%- body %>
  </main>

  <!-- ── FOOTER ── -->
  <footer>
    <%- include('../includes/footer') %>
   
  </footer>

  <%- include("../includes/chat.ejs") %>

  <!-- ── SCRIPTS ── -->

  <!-- Bootstrap JS -->
  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
  ></script>
  <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>

  <!-- Mapbox GL JS -->
  <script src="https://api.mapbox.com/mapbox-gl-js/v2.9.1/mapbox-gl.js"></script>

  <!-- Global JS: tax toggle + search filter -->
  <script>
    // ── Tax toggle ──
    const taxToggle = document.getElementById('taxToggle');
    if (taxToggle) {
      taxToggle.addEventListener('click', () => {
        taxToggle.classList.toggle('active');
        const showTax = taxToggle.classList.contains('active');
        document.querySelectorAll('.tax-info').forEach(el => {
          el.style.display = showTax ? 'inline' : 'none';
        });
      });
    }

    // ── Live search filter (index page) ──
    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        const q = searchInput.value.toLowerCase();
        document.querySelectorAll('.listing-row').forEach(row => {
          const title = (row.dataset.title || '').toLowerCase();
          row.style.display = title.includes(q) ? '' : 'none';
        });
      });
    }

    // ── Bootstrap form validation ──
    (() => {
      'use strict';
      const forms = document.querySelectorAll('.needs-validation');
      Array.from(forms).forEach(form => {
        form.addEventListener('submit', event => {
          if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
          }
          form.classList.add('was-validated');
        }, false);
      });
    })();
  </script>

  <script src="/js/chatbot.js"></script>
  <script src="/js/chart.js"></script>
  <script src="/js/calender.js"></script>
</body>
</html>
