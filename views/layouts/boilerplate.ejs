<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>WanderLust</title>

  <!-- ① Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,600&family=Manrope:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />

  <!-- ② Tabler Icons -->
  <!-- <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/tabler-icons@3.44.0/iconfont/tabler-icons.min.css"
    crossorigin="anonymous"
    referrerpolicy="no-referrer"
  /> -->

  <!-- ③ Font Awesome -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    crossorigin="anonymous"
    referrerpolicy="no-referrer"
  />

  <!-- ④ Bootstrap 5 CSS -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
  />

  <!-- ⑤ Mapbox GL -->
  <link
    href="https://api.mapbox.com/mapbox-gl-js/v2.9.1/mapbox-gl.css"
    rel="stylesheet"
  />

  <!-- ⑥ YOUR custom stylesheet (must come LAST so it overrides Bootstrap) -->
  <link rel="stylesheet" href="/CSS/style.css" />
</head>

<body>

  <!-- ── NAVBAR ── -->
  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid px-0">

      <!-- Brand -->
      <a class="navbar-brand ms-0" href="/listings">
        Wander<span class="brand-accent">Lust</span>
      </a>

      <!-- Mobile toggler -->
      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarNav"
        style="border-color:var(--border)"
      >
        <span class="navbar-toggler-icon"></span>
      </button>

      <!-- Links -->
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto align-items-center gap-1">

          <li class="nav-item">
            <a class="nav-link" href="/listings">Explore</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/chat">Chat</a>
          </li>

          <% if(currUser) { %>
            <!-- Logged-in links -->
            <li class="nav-item">
              <a class="nav-link" href="/listings/new">+ New Listing</a>
            </li>
            <li class="nav-item">
              <form action="/users/logout" method="POST" class="m-0">
                <button type="submit" class="nav-link btn btn-link p-0" style="font-size:0.72rem;letter-spacing:0.5px;text-transform:uppercase;color:var(--muted);">
                  Logout
                </button>
              </form>
            </li>
            <li class="nav-item ms-1">
              <span class="nav-link" style="color:var(--ink);font-weight:600;">
                <i class="ti ti-user-circle" style="font-size:1rem;vertical-align:middle;"></i>
                &nbsp;<%= currUser.username %>
              </span>
            </li>

          <% } else { %>
            <!-- Guest links -->
            <li class="nav-item">
              <a class="nav-link" href="/users/signup">Sign up</a>
            </li>
            <li class="nav-item ms-1">
              <a class="btn-nav-cta" href="/users/login">Log in</a>
            </li>
          <% } %>

        </ul>
      </div>

    </div>
  </nav>
  <!-- ── END NAVBAR ── -->

  <!-- ── FLASH MESSAGES ── -->
  <div class="container-fluid px-0">
    <div style="padding: 0 28px; margin-top: 10px;">
      <%- include('../includes/flash') %>
    </div>
  </div>

  <!-- ── PAGE CONTENT ── -->
  <main>
    <%- body %>
  </main>

  <!-- ── FOOTER ── -->
  <footer>
    <%- include('../includes/footer') %>
   
  </footer>

  <!-- ── SCRIPTS ── -->

  <!-- Bootstrap JS -->
  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
  ></script>

  <!-- Mapbox GL JS -->
  <script src="https://api.mapbox.com/mapbox-gl-js/v2.9.1/mapbox-gl.js"></script>

  <!-- Global JS: filter chips + tax toggle + search filter -->
  <script>
    // ── Filter chips (index page) ──
    document.querySelectorAll('.f-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        document.querySelectorAll('.f-chip').forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
      });
    });

    // ── Tax toggle ──
    const taxToggle = document.getElementById('taxToggle');
    if (taxToggle) {
      taxToggle.addEventListener('click', () => {
        taxToggle.classList.toggle('active');
        const showTax = taxToggle.classList.contains('active');
        document.querySelectorAll('.tax-info').forEach(el => {
          el.style.display = showTax ? 'inline' : 'none';
        });
      });
    }

    // ── Live search filter (index page) ──
    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        const q = searchInput.value.toLowerCase();
        document.querySelectorAll('.listing-row').forEach(row => {
          const title = (row.dataset.title || '').toLowerCase();
          row.style.display = title.includes(q) ? '' : 'none';
        });
      });
    }

    // ── Bootstrap form validation ──
    (() => {
      'use strict';
      const forms = document.querySelectorAll('.needs-validation');
      Array.from(forms).forEach(form => {
        form.addEventListener('submit', event => {
          if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
          }
          form.classList.add('was-validated');
        }, false);
      });
    })();
  </script>

  <script src="/js/chatbot.js"></script>
</body>
</html>
