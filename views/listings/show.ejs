<%- layout("layouts/boilerplate") %>

<!-- ── HERO IMAGE ── -->
<div class="show-img-row">
  <% if(listing.image && listing.image.url) { %>
    <img src="<%= listing.image.url %>" alt="<%= listing.title %>" />
  <% } else { %>
    <div style="font-size:5rem;">🏠</div>
  <% } %>

  <div class="show-over">
    <div>
      <div class="show-place">
        <i class="ti ti-map-pin" style="font-size:11px;"></i>
        <%= listing.location %>, <%= listing.country %>
      </div>
      <div class="show-name"><%= listing.title %></div>
    </div>
    <div class="show-price-tag">
      <span class="amt">&#8377;<%= listing.price.toLocaleString("en-IN") %></span>
      <span class="per">per night</span>
    </div>
  </div>
</div>

  <!-- ── LISTING BODY ── -->
<div class="show-body">

  <div class="owner-text">
    Owned by &nbsp;<b><%= listing.owner && listing.owner.username ? listing.owner.username : 'Unknown' %></b>
  </div>

  <p class="show-desc"><%= listing.description %></p>

  <div class="show-info-row">
    <div class="info-chip">
      <i class="ti ti-map-pin"></i> <%= listing.location %>, <%= listing.country %>
    </div>
    <div class="info-chip">
      <i class="ti ti-currency-rupee"></i>
      <%= listing.price.toLocaleString("en-IN") %> / night
    </div>
    <div class="info-chip">
      <i class="ti ti-calendar"></i> Available now
    </div>
  </div>

  <!-- Edit / Delete — only for owner -->
  <% if(currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
  <div class="show-actions">
    <a href="/listings/<%= listing._id %>/edit" class="btn-edit">
      <i class="ti ti-pencil" style="font-size:13px;vertical-align:middle;"></i>
      Edit listing
    </a>
    <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="m-0">
      <button type="submit" class="btn-delete">
        <i class="ti ti-trash" style="font-size:13px;vertical-align:middle;"></i>
        Delete
      </button>
    </form>
  </div>
  <% } %>

  <!-- ── MAP ── -->
  <% if(listing.geometry && listing.geometry.coordinates) { %>
  <div style="margin-top:24px;">
    <div style="font-size:0.68rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:10px;display:flex;align-items:center;gap:8px;">
      <i class="ti ti-map-2" style="font-size:14px;color:var(--red);"></i>
      Location Map
    </div>
    <div id="map"></div>
    <div style="font-size:0.72rem;color:var(--muted);margin-top:8px;display:flex;align-items:center;gap:6px;">
      <i class="ti ti-info-circle" style="font-size:13px;"></i>
      Exact location shared after booking
    </div>
  </div>
  <% } %>

</div>

<!-- ── REVIEWS SECTION ── -->
<div class="section-hed">
  <div class="hed-rule">
    <span class="hed-title">
      Guest Reviews
      <span style="font-weight:400;color:var(--muted);font-size:0.65rem;margin-left:6px;">
        (<%= listing.reviews.length %>)
      </span>
    </span>
  </div>
</div>

<% if(listing.reviews.length > 0) { %>
<div class="review-strip">
  <% for(let review of listing.reviews) { %>
  <div class="rev-card">
    <div class="rev-user">
      <div class="rev-avatar">
        <%= review.author && review.author.username ? review.author.username.substring(0,2).toUpperCase() : 'AN' %>
      </div>
      <div>
        <div class="rev-name"><%= review.author && review.author.username ? review.author.username : 'Anonymous' %></div>
        <div class="rev-meta">
          <%= listing.title %> &nbsp;·&nbsp;
          <% let d = new Date(review.createdAt || Date.now()); %>
          <%= d.toLocaleDateString('en-IN', {month:'short', year:'numeric'}) %>
        </div>
      </div>
    </div>
    <div class="rev-stars">
      <% for(let i=1; i<=5; i++) { %>
        <span class="<%= i <= review.rating ? 'sf' : 'se' %>">★</span>
      <% } %>
    </div>
    <div class="rev-text"><%= review.comment %></div>
    <% if(currUser && review.author && currUser._id.equals(review.author._id)) { %>
    <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="m-0">
      <button type="submit" class="rev-delete">
        <i class="ti ti-trash" style="font-size:11px;vertical-align:middle;"></i>
        Delete
      </button>
    </form>
    <% } %>
  </div>
  <% } %>
</div>
<% } else { %>
  <div style="padding:24px 28px;color:var(--muted);font-size:0.82rem;border-bottom:0.5px solid var(--border);">
    No reviews yet. Be the first to leave one!
  </div>
<% } %>

<!-- ── REVIEW FORM ── -->
<% if(currUser) { %>
<div class="section-hed">
  <div class="hed-rule">
    <span class="hed-title">Leave a Review</span>
  </div>
</div>
<div class="review-form-section">
  <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation review-form">
    <div class="form-row mb-3">
      <label class="form-label">Your Rating</label>
      <div class="d-flex gap-2 align-items-center" id="starWidget">
        <% for(let i=1; i<=5; i++) { %>
          <span class="star-pick se" data-val="<%= i %>" style="font-size:1.5rem;cursor:pointer;transition:color 0.15s;">★</span>
        <% } %>
        <input type="hidden" name="review[rating]" id="ratingInput" value="4" required />
      </div>
    </div>
    <div class="mb-3">
      <label class="form-label" for="comment">Your Comment</label>
      <textarea name="review[comment]" id="comment" class="form-control" rows="3" placeholder="Share your experience..." required minlength="5"></textarea>
      <div class="invalid-feedback">Please write at least 5 characters.</div>
    </div>
    <button type="submit" class="btn-submit">
      <i class="ti ti-send" style="font-size:13px;vertical-align:middle;"></i>
      Submit Review
    </button>
  </form>
</div>
<% } else { %>
  <div style="padding:20px 28px;border-bottom:0.5px solid var(--border);font-size:0.82rem;color:var(--muted);">
    <a href="/users/login" style="color:var(--red);font-weight:600;text-decoration:none;">Log in</a>
    to leave a review.
  </div>
<% } %>


<style id="map-editorial-style">
  #map {
    height: 380px;
    width: 100%;
    border-radius: 3px;
    border: 0.5px solid #d8cfc5;
    background: #ede6dd;
  }
  .mapboxgl-ctrl-group {
    border-radius: 3px !important;
    border: 0.5px solid #d8cfc5 !important;
    box-shadow: none !important;
    overflow: hidden;
  }
  .mapboxgl-ctrl-group button {
    background: #faf7f3 !important;
    color: #1a1410 !important;
    border: none !important;
    border-bottom: 0.5px solid #d8cfc5 !important;
    width: 32px !important;
    height: 32px !important;
  }
  .mapboxgl-ctrl-group button:last-child { border-bottom: none !important; }
  .mapboxgl-ctrl-group button:hover { background: #ede6dd !important; }
  .mapboxgl-ctrl-icon { filter: invert(20%); }
  .mapboxgl-ctrl-bottom-left,
  .mapboxgl-ctrl-bottom-right { opacity: 0.5; font-size: 10px; }
  .mapboxgl-popup-content {
    font-family: 'Manrope', sans-serif !important;
    background: #faf7f3 !important;
    border: 1px solid #d8cfc5 !important;
    border-radius: 4px !important;
    box-shadow: 0 4px 20px rgba(26,20,16,0.12) !important;
    padding: 0 !important;
    min-width: 200px;
  }
  .mapboxgl-popup-anchor-bottom .mapboxgl-popup-tip { border-top-color: #d8cfc5 !important; }
  .mapboxgl-popup-anchor-top .mapboxgl-popup-tip   { border-bottom-color: #d8cfc5 !important; }
  .mapboxgl-popup-close-button {
    color: #8a7f78 !important;
    font-size: 16px !important;
    padding: 6px 8px !important;
    background: none !important;
    border: none !important;
    line-height: 1 !important;
  }
  .mapboxgl-popup-close-button:hover { color: #d94f3d !important; }
  .custom-marker {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #d94f3d;
    border: 2.5px solid #faf7f3;
    box-shadow: 0 0 0 2px #d94f3d, 0 2px 8px rgba(217,79,61,0.4);
    cursor: pointer;
    animation: markerPulse 2s infinite;
  }
  @keyframes markerPulse {
    0%   { box-shadow: 0 0 0 2px #d94f3d, 0 0 0 0   rgba(217,79,61,0.4); }
    70%  { box-shadow: 0 0 0 2px #d94f3d, 0 0 0 10px rgba(217,79,61,0);   }
    100% { box-shadow: 0 0 0 2px #d94f3d, 0 0 0 0   rgba(217,79,61,0);   }
  }
</style>

<!-- ── SCRIPTS ── -->
<script>
  // ── Star rating widget ──
  const stars  = document.querySelectorAll('.star-pick');
  const rInput = document.getElementById('ratingInput');
  let current  = 4;

  function paintStars(val) {
    stars.forEach(function(s) {
      s.style.color = parseInt(s.dataset.val) <= val ? '#d94f3d' : '#d8cfc5';
    });
  }
  paintStars(current);

  stars.forEach(function(s) {
    s.addEventListener('mouseenter', function() { paintStars(parseInt(s.dataset.val)); });
    s.addEventListener('mouseleave', function() { paintStars(current); });
    s.addEventListener('click', function() {
      current = parseInt(s.dataset.val);
      rInput.value = current;
      paintStars(current);
    });
  });

  // ── Mapbox map ──
  <% if(listing.geometry && listing.geometry.coordinates) { %>

  // Defer initialization until Mapbox GL is available and DOM is ready
  document.addEventListener('DOMContentLoaded', function() {
    (function waitForMapbox() {
      if (typeof mapboxgl === 'undefined') {
        return setTimeout(waitForMapbox, 120);
      }

      mapboxgl.accessToken = '<%= process.env.MAP_TOKEN %>';

      var map = new mapboxgl.Map({
        container: 'map',
        style: 'mapbox://styles/mapbox/light-v11',
        center: <%- JSON.stringify(listing.geometry.coordinates) %>,
        zoom: 10,
        attributionControl: false
      });

      map.addControl(new mapboxgl.NavigationControl({ showCompass: false }), 'top-right');
      map.addControl(new mapboxgl.AttributionControl({ compact: true }), 'bottom-right');

      // Custom pulsing marker element
      var markerEl = document.createElement('div');
      markerEl.className = 'custom-marker';

      // Popup HTML — built with plain string concat, NO backticks
      var popupHTML =
        '<div style="padding:14px 16px 12px;">' +
          '<div style="font-size:0.6rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#d94f3d;margin-bottom:6px;">' +
            '\u{1F4CD} <%= listing.location %>, <%= listing.country %>' +
          '</div>' +
          '<div style="font-family:\'Playfair Display\',serif;font-size:1rem;font-style:italic;color:#1a1410;line-height:1.3;margin-bottom:8px;">' +
            '<%= listing.title %>' +
          '</div>' +
          '<div style="display:flex;align-items:center;justify-content:space-between;padding-top:8px;border-top:0.5px solid #d8cfc5;">' +
            '<span style="font-size:0.72rem;color:#8a7f78;">per night</span>' +
            '<span style="font-size:0.95rem;font-weight:700;color:#1a1410;">&#8377;<%= listing.price.toLocaleString("en-IN") %></span>' +
          '</div>' +
        '</div>';

      var popup = new mapboxgl.Popup({
        offset: 20,
        closeButton: true,
        closeOnClick: false,
        maxWidth: '240px'
      }).setHTML(popupHTML);

      new mapboxgl.Marker(markerEl)
        .setLngLat(<%- JSON.stringify(listing.geometry.coordinates) %>)
        .setPopup(popup)
        .addTo(map);

      // Auto-open popup after map loads
      map.on('load', function() {
        popup.addTo(map);

        // Accessibility: ensure popup close button is focusable and manage focus
        var mapContainer = map.getContainer();
        if (mapContainer && !mapContainer.hasAttribute('tabindex')) {
          mapContainer.setAttribute('tabindex', '0');
        }

        var popupEl = popup.getElement && popup.getElement();
        if (popupEl) {
          var closeBtn = popupEl.querySelector && popupEl.querySelector('.mapboxgl-popup-close-button');
          if (closeBtn) {
            // Remove aria-hidden if present and ensure label
            closeBtn.removeAttribute && closeBtn.removeAttribute('aria-hidden');
            if (!closeBtn.hasAttribute('aria-label')) closeBtn.setAttribute('aria-label', 'Close popup');
            closeBtn.tabIndex = 0;
            try { closeBtn.focus(); } catch (e) {}

            // When popup closes, move focus back to the map container
            if (popup && popup.on) {
              popup.on('close', function() {
                try { mapContainer.focus(); } catch (e) {}
              });
            }

            closeBtn.addEventListener && closeBtn.addEventListener('click', function() {
              try { mapContainer.focus(); } catch (e) {}
            });
          }
        }
      });
    })();
  });

  <% } %>
</script>
