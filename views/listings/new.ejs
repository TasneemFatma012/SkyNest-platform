<%- layout("layouts/boilerplate") %>

<div class="form-page">

  <div class="form-page-title">Create a new Listing</div>
  <div class="form-page-sub">
    Fill in the details below — your stay will be live instantly.
  </div>

  <div class="form-card">
    <form
      method="POST"
      action="/listings"
      novalidate
      class="needs-validation"
      enctype="multipart/form-data"
    >

      <!-- Title -->
      <div class="mb-3">
        <label class="form-label" for="title">Title</label>
        <input
          id="title"
          name="listing[title]"
          type="text"
          class="form-control"
          placeholder="e.g. Cozy Himalayan Chalet"
          required
        />
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Title is required.</div>
      </div>

      <!-- Description -->
      <div class="mb-3">
        <label class="form-label" for="description">Description</label>
        <textarea
          id="description"
          name="listing[description]"
          class="form-control"
          rows="4"
          placeholder="Describe your place — views, vibe, amenities..."
          required
        ></textarea>
        <div class="invalid-feedback">Please add a description.</div>
      </div>

      <!-- Image upload -->
      <div class="mb-3">
        <label class="form-label" for="image">
          <i class="ti ti-photo" style="vertical-align:middle;margin-right:4px;"></i>
          Upload Image
        </label>
        <input
          id="image"
          name="listing[image]"
          type="file"
          class="form-control"
          accept="image/*"
          required
        />
        <div class="invalid-feedback">Please upload an image.</div>
      </div>

      <!-- Price + Country (side by side) -->
      <div class="row g-3 mb-3">
        <div class="col-md-4">
          <label class="form-label" for="price">Price (₹ / night)</label>
          <input
            id="price"
            name="listing[price]"
            type="number"
            class="form-control"
            placeholder="e.g. 3500"
            min="0"
            required
          />
          <div class="invalid-feedback">Enter a valid price.</div>
        </div>
        <div class="col-md-8">
          <label class="form-label" for="country">Country</label>
          <input
            id="country"
            name="listing[country]"
            type="text"
            class="form-control"
            placeholder="e.g. India"
            required
          />
          <div class="invalid-feedback">Country is required.</div>
        </div>
      </div>

      <!-- Location -->
      <div class="mb-4">
        <label class="form-label" for="location">
          <i class="ti ti-map-pin" style="vertical-align:middle;margin-right:4px;"></i>
          Location
        </label>
        <input
          id="location"
          name="listing[location]"
          type="text"
          class="form-control"
          placeholder="e.g. Manali, Himachal Pradesh"
          required
        />
        <div class="invalid-feedback">Location is required.</div>
      </div>

      <button type="submit" class="add-btn btn">
        <i class="ti ti-plus" style="font-size:13px;vertical-align:middle;"></i>
        Add Listing
      </button>

    </form>
  </div>

  <div class="form-link mt-3">
    Changed your mind? <a href="/listings">Back to listings</a>
  </div>

</div>
