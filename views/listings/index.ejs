<%- layout("layouts/boilerplate") %>

<!-- ── SEARCH BAR ── -->
<div class="search-row">
  <div class="search-wrap">
    <i class="ti ti-search"></i>
    <input
      type="text"
      id="searchInput"
      placeholder="Search destinations, stays, experiences..."
      autocomplete="off"
    />
  </div>
  <button class="search-btn">Search</button>
</div>

<!-- ── ISSUE BAR ── -->
<div class="issue-bar">
  <span class="issue-label">
    WanderLust &nbsp;·&nbsp; <%= allListings.length %> curated stays
  </span>
  <div class="tax-pill">
    <span>Show price with taxes</span>
    <div class="toggle-track" id="taxToggle">
      <div class="toggle-thumb"></div>
    </div>
  </div>
</div>

<!-- ── FILTER CHIPS ── -->
<div class="filter-scroll">
  
  <div class="f-chip active">
    <i class="fa fa-fire fc-icon"></i>
    <span class="fc-lbl">Trending</span>
  </div>

  <div class="f-chip">
    <i class="fa fa-bed fc-icon"></i>
    <span class="fc-lbl">Rooms</span>
  </div>

  <div class="f-chip">
    <i class="fa fa-city fc-icon"></i>
    <span class="fc-lbl">City</span>
  </div>

  <div class="f-chip">
    <i class="fa fa-mountain fc-icon"></i>
    <span class="fc-lbl">Mountains</span>
  </div>

  <div class="f-chip">
    <i class="fa fa-tree fc-icon"></i>
    <span class="fc-lbl">Nature</span>
  </div>

  <div class="f-chip">
    <i class="fa fa-umbrella-beach fc-icon"></i>
    <span class="fc-lbl">Beach</span>
  </div>

  <div class="f-chip">
    <i class="fa fa-campground fc-icon"></i>
    <span class="fc-lbl">Camping</span>
  </div>

  <div class="f-chip">
    <i class="fa fa-home fc-icon"></i>
    <span class="fc-lbl">Homes</span>
  </div>

  <div class="f-chip">
    <i class="fa fa-snowflake fc-icon"></i>
    <span class="fc-lbl">Arctic</span>
  </div>

  <div class="f-chip">
    <i class="fa fa-tractor fc-icon"></i>
    <span class="fc-lbl">Farms</span>
  </div>

</div>

<!-- ── HERO STRIP (first 3 listings) ── -->
<% if(allListings.length >= 3) { %>
<div class="hero-strip">

  <!-- Main featured card — first listing -->
  <a href="/listings/<%= allListings[0]._id %>" class="hero-main" style="text-decoration:none;">
    <div class="hero-bg-text">WL</div>
    <% if(allListings[0].image && allListings[0].image.url) { %>
      <img
        src="<%= allListings[0].image.url %>"
        alt="<%= allListings[0].title %>"
        style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.45;"
      />
    <% } %>
    <div style="position:relative;z-index:1;">
      <div class="hero-tag">✦ Editor's pick</div>
      <div class="hero-title"><%= allListings[0].title %></div>
      <div class="hero-sub">
        <i class="ti ti-map-pin" style="font-size:12px;"></i>
        <%= allListings[0].location %>, <%= allListings[0].country %>
      </div>
      <div class="hero-price">
        <strong>&#8377;<%= allListings[0].price.toLocaleString("en-IN") %></strong>
        <span>/ night</span>
      </div>
    </div>
  </a>

  <!-- Side cards — 2nd and 3rd listings -->
  <div class="hero-side">
    <a href="/listings/<%= allListings[1]._id %>" class="side-top" style="text-decoration:none;position:relative; overflow:hidden;">
      <% if(allListings[1].image && allListings[1].image.url) { %>
        <img
          src="<%= allListings[1].image.url %>"
          alt="<%= allListings[1].title %>"
          style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.3;"
        />
      <% } %>
      <div style="position:relative;z-index:2;">
      <div class="side-tag">Trending</div>
      <div class="side-title"><%= allListings[1].title %></div>
      <div class="side-price">
        &#8377;<%= allListings[1].price.toLocaleString("en-IN") %> / night
      </div>
      </div>
    </a>

    <a href="/listings/<%= allListings[2]._id %>" class="side-bottom" style="text-decoration:none;position:relative; overflow:hidden;">
      <div class="side-tag">Unique stay</div>
      <div class="side-title"><%= allListings[2].title %></div>
      <div class="side-price">
        &#8377;<%= allListings[2].price.toLocaleString("en-IN") %> / night
      </div>
    </a>
  </div>

</div>
<% } %>

<!-- ── ALL LISTINGS LIST ── -->
<div class="section-hed">
  <div class="hed-rule">
    <span class="hed-title">All Listings</span>
  </div>
  <% if(currUser) { %>
    <a href="/listings/new" class="hed-link">+ Add new →</a>
  <% } %>
</div>

<div class="cards-grid">
  <% for(let listing of allListings.slice(3)) { %>
  <a href="/listings/<%= listing._id %>" class="listing-card">

    <div class="card-img">
      <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
      
      <form action="/wishlist/<%= listing._id %>" method="POST">

      <button class="wishlist-btn">
        <i class="fa-regular fa-heart"></i>
      </button>
      </form>

      <div class="card-price">
        ₹<%= listing.price.toLocaleString("en-IN") %>/night
      </div>
    </div>

    <div class="card-body">
      <h3><%= listing.title %></h3>

      <p class="location">
        📍 <%= listing.location %>, <%= listing.country %>
      </p>

      <div class="rating">
        ⭐ 4.8 (124 Reviews)
      </div>

      <% if(currUser){ %>
        <a href="/bookings/<%= listing._id %>" class="book-btn">
          Book Now
        </a>
      <% } else { %>
        <a href="/login" class="book-btn">
          Login to Book
        </a>
      <% } %>  

    </div>

  </a>
  <% } %>
</div>

<!-- ── PULL QUOTE ── -->
<div class="pullquote">
  <div class="pq-bar"></div>
  <div>
    <div class="pq-text">
      "Travelling — it leaves you speechless, then turns you into a storyteller."
    </div>
    <div class="pq-attr">— Ibn Battuta &nbsp;·&nbsp; Explorer</div>
  </div>
</div>