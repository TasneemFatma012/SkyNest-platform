    /* FILTER BAR */
.filters {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 1.5rem;
  padding: 1rem 2rem;
  border-bottom: 1px solid #ddd;
}

.filter {
  text-align: center;
  opacity: 0.6;
  transition: all 0.3s ease;
}

.filter i {
  font-size: 1.3rem;
}

.filter p {
  font-size: 0.75rem;
  margin-top: 0.3rem;
}

.filter:hover {
  opacity: 1;
  transform: scale(1.05);
  cursor: pointer;
}

/* TAX TOGGLE */
.tax-toggle {
  margin-left: auto;
  border: 1px solid #ccc;
  border-radius: 2rem;
  padding: 0.5rem 1rem;
  background-color: #f8f8f8;
}

/* LISTING CARDS */
.listing-card {
  border: none !important;
  border-radius: 1rem !important;
  overflow: hidden;
  transition: all 0.3s ease;
}

.listing-card img {
  border-radius: 1rem;
  object-fit: cover;
}

/* CARD HOVER EFFECT */
.listing-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 8px 20px rgba(0,0,0,0.15);
}

/* REMOVE LINK STYLE */
.listing-link {
  text-decoration: none;
  color: black;
}

/* CARD TEXT */
.card-text {
  font-size: 0.9rem;
}

.card-text b {
  font-size: 1rem;
}

/* TAX INFO */
.tax-info {
  display: none;
  color: green;
  font-weight: 500;
  margin-left: 5px;
}
/* TOGGLE CONTAINER */
.tax-toggle {
  margin-left: auto;
  background: #fff;
  border-radius: 2rem;
  padding: 0.5rem 1rem;
  box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  display: flex;
  align-items: center;
}

/* SWITCH WRAPPER */
.tax-switch {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

/* LABEL */
.tax-toggle label {
  font-size: 0.9rem;
  color: #333;
  cursor: pointer;
}

/* SWITCH SIZE */
.form-switch .form-check-input {
  width: 2.5rem;
  height: 1.3rem;
  cursor: pointer;
}

/* CUSTOM ACTIVE COLOR */
.form-switch .form-check-input:checked {
  background-color: #fe424d;
  border-color: #fe424d;
}

/* HOVER EFFECT */
.tax-toggle:hover {
  transform: scale(1.02);
  transition: 0.2s ease;
}
    </style>
