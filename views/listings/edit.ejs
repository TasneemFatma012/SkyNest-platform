<%- layout("layouts/boilerplate") %>

<div class="form-page">

  <div class="form-page-title">Edit your Listing</div>
  <div class="form-page-sub">
    Update the details below — changes go live immediately.
  </div>

  <div class="form-card">
    <form
      method="POST"
      action="/listings/<%= listing._id %>?_method=PUT"
      novalidate
      class="needs-validation"
      enctype="multipart/form-data"
    >

      <!-- Title -->
      <div class="mb-3">
        <label class="form-label" for="title">Title</label>
        <input
          id="title"
          name="listing[title]"
          value="<%= listing.title %>"
          type="text"
          class="form-control"
          required
        />
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Title is required.</div>
      </div>

      <!-- Description -->
      <div class="mb-3">
        <label class="form-label" for="description">Description</label>
        <textarea
          id="description"
          name="listing[description]"
          class="form-control"
          rows="4"
          required
        ><%= listing.description %></textarea>
        <div class="invalid-feedback">Please add a description.</div>
      </div>

      <!-- Current image preview -->
      <% if(listing.image && listing.image.url) { %>
      <div class="mb-3">
        <label class="form-label">Current Image</label>
        <img
          src="<%= originalImageUrl || listing.image.url %>"
          alt="Current listing image"
          class="edit-img"
        />
      </div>
      <% } %>

      <!-- Replace image -->
      <div class="mb-3">
        <label class="form-label" for="image">
          <i class="ti ti-photo" style="vertical-align:middle;margin-right:4px;"></i>
          Replace Image <span style="color:var(--muted);font-weight:400;text-transform:none;letter-spacing:0;">(optional)</span>
        </label>
        <input
          id="image"
          name="listing[image]"
          type="file"
          class="form-control"
          accept="image/*"
        />
      </div>

      <!-- Price + Country -->
      <div class="row g-3 mb-3">
        <div class="col-md-4">
          <label class="form-label" for="price">Price (₹ / night)</label>
          <input
            id="price"
            name="listing[price]"
            value="<%= listing.price %>"
            type="number"
            class="form-control"
            min="0"
            required
          />
          <div class="invalid-feedback">Enter a valid price.</div>
        </div>
        <div class="col-md-8">
          <label class="form-label" for="country">Country</label>
          <input
            id="country"
            name="listing[country]"
            value="<%= listing.country %>"
            type="text"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Country is required.</div>
        </div>
      </div>

      <!-- Location -->
      <div class="mb-4">
        <label class="form-label" for="location">
          <i class="ti ti-map-pin" style="vertical-align:middle;margin-right:4px;"></i>
          Location
        </label>
        <input
          id="location"
          name="listing[location]"
          value="<%= listing.location %>"
          type="text"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Location is required.</div>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="edit-btn btn">
          <i class="ti ti-device-floppy" style="font-size:13px;vertical-align:middle;"></i>
          Save Changes
        </button>
        <a href="/listings/<%= listing._id %>" class="btn-edit" style="background:var(--warm2);color:var(--ink);">
          Cancel
        </a>
      </div>

    </form>
  </div>

</div>
