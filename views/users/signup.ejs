<%- layout("layouts/boilerplate") %>

<div class="form-page">

  <div class="form-page-title">Join WanderLust</div>
  <div class="form-page-sub">
    Create your free account and start exploring — or hosting.
  </div>

  <div class="form-card">
    <form
      method="POST"
      action="/users/signup"
      novalidate
      class="needs-validation"
    >

      <!-- Username -->
      <div class="mb-3">
        <label class="form-label" for="username">
          <i class="ti ti-user" style="vertical-align:middle;margin-right:4px;"></i>
          Username
        </label>
        <input
          id="username"
          name="username"
          type="text"
          class="form-control"
          placeholder="e.g. travellerrahul"
          required
        />
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Username is required.</div>
      </div>

      <!-- Email -->
      <div class="mb-3">
        <label class="form-label" for="email">
          <i class="ti ti-mail" style="vertical-align:middle;margin-right:4px;"></i>
          Email
        </label>
        <input
          id="email"
          name="email"
          type="email"
          class="form-control"
          placeholder="e.g. rahul@email.com"
          required
        />
        <div class="invalid-feedback">Enter a valid email.</div>
      </div>

      <!-- Password -->
      <div class="mb-4">
        <label class="form-label" for="password">
          <i class="ti ti-lock" style="vertical-align:middle;margin-right:4px;"></i>
          Password
        </label>
        <input
          id="password"
          name="password"
          type="password"
          class="form-control"
          placeholder="Min. 6 characters"
          required
          minlength="6"
        />
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Password must be at least 6 characters.</div>
      </div>

      <button type="submit" class="add-btn btn w-100">
        Create Account
      </button>

    </form>
  </div>

  <div class="form-link mt-3">
    Already have an account? <a href="/users/login">Log in</a>
  </div>

</div>
