<%- layout("layouts/boilerplate") %>

<div class="form-page">

  <div class="form-page-title">Welcome back</div>
  <div class="form-page-sub">
    Log in to your SkyNest account.
  </div>

  <div class="form-card">
    <form
      action="/users/login"
      method="POST"
      novalidate
      class="needs-validation"
    >

      <!-- Username -->
      <div class="mb-3">
        <label class="form-label" for="username">
          <i class="ti ti-user" style="vertical-align:middle;margin-right:4px;"></i>
          Username
        </label>
        <input
          id="username"
          name="username"
          type="text"
          class="form-control"
          placeholder="Enter your username"
          required
        />
        <div class="invalid-feedback">Username is required.</div>
      </div>

      <!-- Password -->
      <div class="mb-4">
        <label class="form-label" for="password">
          <i class="ti ti-lock" style="vertical-align:middle;margin-right:4px;"></i>
          Password
        </label>
        <input
          id="password"
          name="password"
          type="password"
          class="form-control"
          placeholder="Enter your password"
          required
        />
        <div class="invalid-feedback">Password is required.</div>
      </div>

      <button type="submit" class="add-btn btn w-100">
        <i class="ti ti-login" style="font-size:13px;vertical-align:middle;"></i>
        Log In
      </button>

    </form>
  </div>

  <div class="form-link mt-3">
    Don't have an account? <a href="/users/signup">Sign up free</a>
  </div>

</div>
