<%- layout("layouts/boilerplate") %>

<div class="chat-page container">
  <div class="chat-hero">
    <div>
      <div class="chat-hero-eyebrow">WanderLust Assistant</div>
      <h1>Ask the travel chatbot</h1>
      <p>Need help finding a stay, comparing prices, or picking the perfect destination? Send a message and I’ll point you in the right direction.</p>
    </div>
  </div>

  <div class="chat-panel">
    <div class="chat-window" id="chatWindow" aria-live="polite" aria-label="Chat conversation">
      <div class="chat-message bot active">Hello! I'm your WanderLust assistant. What would you like to explore today?</div>
    </div>

    <form id="chatForm" class="chat-form" autocomplete="off">
      <label for="chatInput" class="visually-hidden">Type your message</label>
      <input id="chatInput" name="text" type="text" placeholder="Ask about listings, destinations, or travel tips..." />
      <button type="submit">Send</button>
    </form>
  </div>
</div>
